NODE_ENV=development
PORT=4000

DATABASE_URL=postgresql://user:password@postgres:5432/caregiver_app

JWT_SECRET=change_this_secret
JWT_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=10

MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxx
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_WEBHOOK_URL=https://<ngrok-or-domain>/api/payments/webhook

LLM_API_KEY=sk-xxxxxxxx
LLM_MODEL=claude-sonnet-4-6

MATCHING_IMMEDIATE_TIMEOUT_SECONDS=60
MATCHING_RESCHEDULE_TIMEOUT_MINUTES=15
